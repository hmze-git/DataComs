#BASE IMAGE IS BASICALLY STARTING POINT
#THINK OF IT LIKE THE BLUEPRINT/STARTING POINT THAT YOU ADD STUFF ONTO
#PROVDES DEFAULT PROPERTIES AND METHODS
FROM python:3.13-slim


#GOES TO DIRECTORY WHERE WELLL BE WORKING
#THINK CD'ing IN IN ORDER TO START SERVER 
#ALSO PLACES ALL SUBSEQUENT PACKAGE INSTALLATIONS AND STUFF INSDE IT
#AS ALL COMMANDS RUN FROM WITHIN /APP
WORKDIR /app 

#COPIES ALL PACKAGES INTO THE APP DIRECTORY
#WHEN THE NPM INSTALL RUNS ITLL INSTALL ALL THE PACKAGES WE NEED
COPY requirements.txt .


#INSTALL DEPENDENCIES
RUN pip install -r requirements.txt


#COPY THE REST OF THE FILES INTO THE DIRECTORY (REMEBER TO CREATE DOCKER IGNORE TO IGNORE THE NODE_MODULES)
#LEFT SIDE OF COPY IS LOCAL MACHINE
#RIGHT SIDE IS THE INSIDE OF THE CONTAINER RELATIVE TO WORKDIR
COPY . .



#ADD WAIT HERE  FOR CONTAINER TO WAIT 
# stops api when db isnt ready check usb for the script that runs this if needed
COPY wait-for-it.sh /usr/local/bin/wait-for-it.sh
RUN chmod +x /usr/local/bin/wait-for-it.sh


#SET THE API ENVIRONMENT VARIABLE NAME HAS TO MATCH WITH WHAT YOU HAVE IN YOUR ENV
# Do later this is for when env vars are set up for now this should work
#ENV API_PORT=3001

#EXPOSE PORT SO ITS VISIBLE TO THE PC THIS WAY WHEN RUNNING API THRU DOCKER SAY RUN PORT 3001
EXPOSE 5000



#WHEN CONTAINER IS RUN ITLL RUN THIS WITHIN IT STARTING THE SERVER
#3 minute wait  guarentees the db is ready before api trries to connect s
CMD ["wait-for-it.sh","--timeout=360", "db:3306", "--", "python", "test.py"]